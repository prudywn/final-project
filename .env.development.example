# Neon Local development - copy to .env.development
# Get these from https://console.neon.tech

NEON_API_KEY=your_neon_api_key
NEON_PROJECT_ID=your_neon_project_id
NEON_PARENT_BRANCH_ID=your_neon_parent_branch_id
# Optional: omit PARENT_BRANCH_ID to use your project's default branch

JWT_SECRET=your_jwt_secret
ARCJET_KEY=your_arcjet_key

DATABASE_URL=postgres://neon:npg@neon-local:5432/neondb
DATABASE_NAME=neondb
